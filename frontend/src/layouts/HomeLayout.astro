---
export interface Props {
	title : string,
    frontmatter? : HomePageFrontmatter
}
type HomePageFrontmatter = {
    title: string
    layout: string
    leftlink : string
    lefttext : string
    rightlink : string
    righttext : string
};
import Layout from './Layout.astro';
import GLSLCanvas from '../components/GLSLCanvas.astro';
const props : Props = Astro.props; //frontmatter = astro.props.frontmatter
let frontmatter : HomePageFrontmatter | undefined = props?.frontmatter;
---
<Layout title={props.title}>
<GLSLCanvas src="public/fuji.glsl" class="home-banner" height="min(30vh, 300px)"/>
<div class="credit">
    <a href="https://www.shadertoy.com/user/kaiware007">kaiware007</a>
</div>
<div class="pfp"></div>
<div class="navigator">
    <a target='_blank' href="https://www.youtube.com/channel/UCDp6SYcFblFx5udgwHe5Shg/featured">Youtube</a>
    <slot  name='link2'>{ frontmatter ? <a href = {frontmatter.leftlink} > {frontmatter.lefttext} </a> : <a>placeholder2</a>}</slot>
    <a class= 'pfp-placeholder' href=""></a>
    <slot  name='link3'>{ frontmatter ? <a href = {frontmatter.rightlink} > {frontmatter.righttext} </a> : <a>placeholder3</a>}</slot> 
    <a href="/spring 25 resume.pdf" target="_blank" data-cold download>Resume</a>
</div>
<div class={frontmatter?'mdcontainer':''}> <slot></slot> </div>
</Layout>


<style>

    :global(h1)
    {
        text-align: center;
        font-size: 2.5em;
        color : var(--headertxt);
    }

    :global(.home-banner){
        z-index: 3;
    }
    .credit
    {
        position:absolute;
        top:.75rem;
        right:.75rem;
    }

    /* :global(p) :global(img)
    {
        max-width: 100%;
        max-height: 500px;
        object-fit: contain;
        margin: 25px auto;
        display: block;
    } */

    .mdcontainer
    {
        width:60%;
        margin:auto;
        margin-top:100px;
        font-size : 1.1em;
    }


    .pfp
    {
        --picsize: 100px;
        width: var(--picsize);
        height: var(--picsize);
        margin: calc(-1 * var(--picsize)/2) auto;
        border-radius: 50px;
        background-image: url('images/me portrait.jpg');
        background-position: center;
        background-size: cover;
        z-index: 100;
        position:relative;
    }
    .navigator
        {
            display:grid;
            grid-template-columns: repeat(5,1fr);
            width: 90%;
            margin : 10px auto;
            font-size : 1.25rem;
        }

    .navigator :global(a) /*style elements while ignoring scope. THE SPACING IS IMPORTANT HERE.*/
    {
        color: var(--headertxt);
        text-decoration: inherit;
        margin : auto;
    }
    
    .navigator :global(a:hover)
    {
        color : var(--secondtext);
    }
    
    .pfp-placeholder
    {
        width: 100px;
        display: block;
    }
    
    @media (width<400px)
    {
        .navigator
        {
            grid-template-columns: repeat(3,1fr);
        }
    
        .pfp-placeholder
        {
            grid-column:2/2;
            grid-row:1/3;
        }
    }
</style>