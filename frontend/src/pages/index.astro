---
import HomeLayout from '../layouts/HomeLayout.astro';
import { getCollection, getEntries, getEntry } from 'astro:content';
// import ArticlePreview from '../components/ArticlePreview.astro';
import RedditStylePreview from '../components/RedditStylePreview.astro';
const posts = await getCollection('blog');
---

<HomeLayout title="Home">
	<a href="/about" slot='link2'>About</a>
	<a href="/contact" slot='link3'>Contact</a>
	<div class="blogtitle">
		<h1>Blog</h1>
		<p>Personal Website of Daniel Gutierrez</p>
	</div>
	<main class='posts-holder'>
		{ 
			posts.sort( (a,b) => {return b.data.postnum - a.data.postnum} )
			.map( post => <RedditStylePreview 
			title={post.data.title} 
			description={post.data.description}
			preview={post.data.preview}
			url={ '/posts/' + post.id}
			date={post.data.published}></RedditStylePreview>)
		}<!--Turns out you need to spread the array because of serialization reasons?-->
	</main>
</HomeLayout>

<style>

.blogtitle
{
	border-bottom: 1px solid grey;
	width:66%;
	margin : 100px auto;;
}

.blogtitle>h1
{
	text-align: center;
	color: #fff;
	font-size: 2.5em;
}

.blogtitle>p
{
	text-align: center;
	font-size: 1.25em;
	color:#ccc;
}

.posts-holder
{
	display:grid;
	/* grid-template-columns:repeat(var(--numcols),1fr); */
	grid-template-columns: 1fr;
	gap:25px;
	margin-top:100px;
	grid-auto-rows: 1fr;
	width:66%;
	margin-left: auto;
	margin-right:auto;
}

@media(width<500px)
{
	.posts-holder{width:95%;}
}
</style>
